{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "next-env.d.ts"],
  "exclude": ["node_modules", "dist", "build"],
  "references": [
    {
      "path": "../../libs/shared/core-routes"
    },
    {
      "path": "../../libs/shared/deriv-api"
    },
    {
      "path": "../../libs/shared/theme"
    },
    {
      "path": "../../libs/shared/ui"
    },
    {
      "path": "../../libs/shared/supabase"
    },
    {
      "path": "../../libs/shared/shared-auth"
    },
    {
      "path": "../../libs/shared/shared-config"
    }
  ]
}

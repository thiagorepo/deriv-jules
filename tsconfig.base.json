{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "paths": {
      "@org/core-routes": ["libs/shared/core-routes/src/index.ts"],
      "@org/shared-config": ["libs/shared/shared-config/src/index.ts"],
      "@org/theme": ["libs/shared/theme/src/index.ts"],
      "@org/shared-auth": ["libs/shared/shared-auth/src/index.ts"],
      "@org/supabase": ["libs/shared/supabase/src/index.ts"],
      "@org/ui": ["libs/shared/ui/src/index.ts"]
    }
  }
}

# ─── Supabase ────────────────────────────────────────────────────────────────
# Public URL and anon key for browser-side Supabase client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Publishable default key (used by @org/shared-supabase browser client)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here
# Server-side service role key — NEVER expose this to the browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/deriv_jules

# ─── Deriv API ───────────────────────────────────────────────────────────────
DERIV_API_URL=https://ws.binaryws.com/websockets/v3
DERIV_APP_ID=your-deriv-app-id

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_VERSION=0.0.1
SENTRY_DSN=

# ─── Tenant Configuration ────────────────────────────────────────────────────
# Set per-tenant in each tenant app's .env.local
NEXT_PUBLIC_TENANT_ID=local
NEXT_PUBLIC_TENANT_NAME=Local Broker
NEXT_PUBLIC_THEME=dark
NEXT_PUBLIC_PRIMARY_COLOR=#10b981
NEXT_PUBLIC_LOGIN_REDIRECT=/dashboard

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Set to "true" to enable, "false" or omit to disable
NEXT_PUBLIC_FEATURE_ADVANCED_TRADING=false
NEXT_PUBLIC_FEATURE_BETA_UI=false
NEXT_PUBLIC_FEATURE_CRYPTO=false
NEXT_PUBLIC_FEATURE_DARK_MODE=true
NEXT_PUBLIC_FEATURE_DERIVATIVES=false
NEXT_PUBLIC_FEATURE_TENANT_MANAGEMENT=false
NEXT_PUBLIC_FEATURE_USER_MANAGEMENT=true

# ─── Analytics (optional) ────────────────────────────────────────────────────
NEXT_PUBLIC_ANALYTICS_ID=
